<Window x:Class="Moza.ScLink.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ff="clr-namespace:Moza.ScLink.App.ForceFeedback"
        mc:Ignorable="d"
        Title="MOZA Star Citizen Link"
        Height="560"
        MinHeight="500"
        Width="920"
        MinWidth="820"
        Background="#F4F6F8">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <ff:PreviewRowFormatConverter x:Key="PreviewRowFormat" />
    </Window.Resources>
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="True" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Auto-detect" Command="{Binding AutoDetectCommand}" MinWidth="96" Margin="0,0,8,0" />
                <Button Content="Browse" Command="{Binding BrowseCommand}" MinWidth="78" />
                <Button Content="E-STOP" Command="{Binding ActivateEmergencyStopCommand}"
                        MinWidth="84" Margin="16,0,0,0"
                        Background="#C62828" Foreground="White" FontWeight="Bold" />
            </StackPanel>
            <StackPanel>
                <TextBlock Text="MOZA Star Citizen Link" FontSize="22" FontWeight="SemiBold" Foreground="#17212B" />
                <TextBlock Text="Portable log-driven force feedback bridge" FontSize="13" Foreground="#5B6673" />
            </StackPanel>
        </DockPanel>

        <!-- Red emergency-stop banner stacked ABOVE the amber preview banner (urgency hierarchy). Both
             are conditional and coexist; the Clear button is banner-scoped (relevant only while active). -->
        <Border Grid.Row="1"
                Background="#C62828" BorderBrush="#8E1F1F" BorderThickness="1" CornerRadius="3"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding IsEmergencyStopActive, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="Clear"
                        Command="{Binding ClearEmergencyStopCommand}"
                        MinWidth="84" VerticalAlignment="Center" />
                <TextBlock Foreground="White" FontWeight="Bold" TextWrapping="Wrap" VerticalAlignment="Center"
                           Text="EMERGENCY STOP ACTIVE — force feedback halted. Press Clear to resume." />
            </DockPanel>
        </Border>

        <Border Grid.Row="2"
                Background="#FFF4D6" BorderBrush="#E0B43C" BorderThickness="1" CornerRadius="3"
                Padding="12,8" Margin="0,0,0,12"
                Visibility="{Binding IsPreviewMode, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Foreground="#7A5A00" FontWeight="SemiBold" TextWrapping="Wrap"
                       Text="Preview mode — no device connected (or preview forced). Commands are logged and streamed, not played." />
        </Border>

        <Border Grid.Row="3" Background="White" BorderBrush="#D7DDE4" BorderThickness="1" Padding="14" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Game.log" FontWeight="SemiBold" Foreground="#2A3440" Margin="0,0,10,8" />
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding GameLogPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" Margin="0,0,0,8" />

                <TextBlock Grid.Row="1" Grid.Column="0" Text="Output" FontWeight="SemiBold" Foreground="#2A3440" Margin="0,0,10,8" />
                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="{Binding OutputName}" Foreground="#17212B" FontWeight="SemiBold" />
                    <TextBlock Text=" - " Foreground="#7A8694" />
                    <TextBlock Text="{Binding OutputStatus}" Foreground="#5B6673" />
                </StackPanel>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Status" FontWeight="SemiBold" Foreground="#2A3440" Margin="0,0,10,0" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Status}" Foreground="#17212B" TextWrapping="Wrap" />
            </Grid>
        </Border>

        <DockPanel Grid.Row="4" Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Content="Test Quantum" Command="{Binding TestQuantumCommand}" MinWidth="112" Margin="0,0,8,0" />
                <Button Content="Test Impact" Command="{Binding TestImpactCommand}" MinWidth="104" Margin="0,0,8,0" />
                <Button Content="Test Atmo" Command="{Binding TestAtmosphereCommand}" MinWidth="96" />
            </StackPanel>
            <CheckBox Content="Preview mode (applies on next launch)"
                      IsChecked="{Binding ForcePreviewMode}"
                      VerticalAlignment="Center" Foreground="#2A3440" />
        </DockPanel>

        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="320" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="White" BorderBrush="#D7DDE4" BorderThickness="1" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Event Feed" FontWeight="SemiBold" Foreground="#2A3440" Margin="14,12,14,8" />
                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Events}"
                             BorderThickness="0"
                             FontFamily="Consolas"
                             FontSize="12"
                             Foreground="#17212B" />
                </Grid>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" BorderBrush="#D7DDE4" BorderThickness="1" Margin="0,0,0,12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="14,12,14,8">
                            <Button DockPanel.Dock="Right"
                                    Content="Refresh"
                                    Command="{Binding RefreshDiagnosticsCommand}"
                                    MinWidth="72" />
                            <TextBlock Text="Diagnostics" FontWeight="SemiBold" Foreground="#2A3440" VerticalAlignment="Center" />
                        </DockPanel>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Diagnostics}"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Foreground="#17212B" />
                    </Grid>
                </Border>

                <Border Grid.Row="1" Background="White" BorderBrush="#D7DDE4" BorderThickness="1">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Margin="14,12,14,8">
                            <CheckBox DockPanel.Dock="Right"
                                      Content="Show envelope detail"
                                      IsChecked="{Binding ShowPreviewEnvelopeDetail}"
                                      VerticalAlignment="Center" Foreground="#5B6673" />
                            <TextBlock Text="Preview Output (last 50)" FontWeight="SemiBold" Foreground="#2A3440"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding PreviewCommands}"
                                 BorderThickness="0"
                                 FontFamily="Consolas"
                                 FontSize="12"
                                 Foreground="#17212B"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock TextWrapping="Wrap">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource PreviewRowFormat}">
                                                <!-- LocalDateTime: WallClock (= command.IssuedAt) is UTC (EffectResolver),
                                                     so display in local time to match the Event Feed's local timestamps. -->
                                                <Binding Path="WallClock.LocalDateTime" />
                                                <Binding Path="CommandType" />
                                                <Binding Path="EffectId" />
                                                <Binding Path="FinalIntensity" />
                                                <Binding Path="Envelope" />
                                                <Binding Path="ActiveCount" />
                                                <!-- Reach up to the window DataContext (MainViewModel) for the toggle bool — the
                                                     per-item DataContext is a PreviewedCommand, which does not carry the toggle. -->
                                                <Binding Path="DataContext.ShowPreviewEnvelopeDetail"
                                                         RelativeSource="{RelativeSource AncestorType=Window}" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
