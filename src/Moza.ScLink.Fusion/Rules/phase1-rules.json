{
  "$schema": "../Schemas/fusion-rules.schema.json",
  "schemaVersion": 1,
  "rules": [
    {
      "ruleId": "log-only-quantum-spool-start",
      "producesEventType": "QuantumSpoolStarted",
      "description": "Log sensor reports quantum spool start; single-sensor confirmation.",
      "requirements": [
        { "kind": "Log", "eventType": "log.quantum_spool_start", "weight": 1.0, "required": true }
      ],
      "evidenceWindowMs": 0,
      "minConfidence": 0.6,
      "suppressionKey": "quantum-spool"
    },
    {
      "ruleId": "log-only-quantum-spool-end",
      "producesEventType": "QuantumSpoolEnded",
      "description": "Log sensor reports quantum spool end.",
      "requirements": [
        { "kind": "Log", "eventType": "log.quantum_spool_end", "weight": 1.0, "required": true }
      ],
      "evidenceWindowMs": 0,
      "minConfidence": 0.6,
      "suppressionKey": "quantum-spool"
    },
    {
      "ruleId": "log-only-quantum-jump-exit",
      "producesEventType": "QuantumJumpExit",
      "description": "Log sensor reports quantum jump arrival.",
      "requirements": [
        { "kind": "Log", "eventType": "log.quantum_jump_exit", "weight": 1.0, "required": true }
      ],
      "evidenceWindowMs": 0,
      "minConfidence": 0.6,
      "suppressionKey": "quantum-jump"
    },
    {
      "ruleId": "log-only-atmosphere-entered",
