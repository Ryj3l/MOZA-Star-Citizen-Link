      "requirements": [
        { "kind": "Log", "eventType": "log.atmosphere_exited", "weight": 1.0, "required": true }
      ],
      "evidenceWindowMs": 0,
      "minConfidence": 0.6,
      "suppressionKey": "atmosphere"
    },
    {
