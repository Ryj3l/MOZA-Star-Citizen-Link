        { "kind": "Log", "eventType": "log.weapon_fire", "weight": 1.0, "required": true }
      ],
      "evidenceWindowMs": 0,
      "minConfidence": 0.6,
      "suppressionKey": "weapon-fire"
    },
    {
      "ruleId": "log-only-vehicle-destruction",
      "producesEventType": "VehicleDestruction",
      "description": "Log sensor reports vehicle destruction.",
      "requirements": [
        { "kind": "Log", "eventType": "log.vehicle_destruction", "weight": 1.0, "required": true }
      ],
      "evidenceWindowMs": 0,
