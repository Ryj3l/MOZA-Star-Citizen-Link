<Window x:Class="Moza.ScLink.DiAcquireProbe.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Moza.ScLink.DiAcquireProbe"
        Title="MOZA SC Link — DI Acquire Probe (#83)"
        Width="640" Height="560" MinWidth="520" MinHeight="420">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="140" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="RefreshButton" Content="Refresh devices" Padding="10,4" Click="OnRefreshClick" />
            <TextBlock Text="Cooperative mode:" VerticalAlignment="Center" Margin="16,0,8,0" />
            <RadioButton x:Name="ForegroundMode" Content="Exclusive | Foreground (SC-faithful)"
                         IsChecked="True" VerticalAlignment="Center" Margin="0,0,12,0"
                         ToolTip="Replicates a game's posture. DirectInput auto-unacquires this mode when the probe window loses focus — keep the probe foreground and use the app's global e-stop hotkey." />
            <RadioButton x:Name="BackgroundMode" Content="Exclusive | Background"
                         VerticalAlignment="Center"
                         ToolTip="Holds acquisition regardless of window focus (sustained-hold variant)." />
        </StackPanel>

        <ListBox x:Name="DeviceList" Grid.Row="1" SelectionChanged="OnDeviceSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="{x:Type local:DeviceItem}">
                    <TextBlock Text="{Binding Display}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsTarget}" Value="True">
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,8,0,8">
            <Button x:Name="AcquireButton" Content="Acquire" Padding="14,6" IsEnabled="False" Click="OnAcquireClick" />
            <Button x:Name="ResetButton" Content="Reset FFB" Padding="14,6" Margin="8,0,0,0" IsEnabled="False" Click="OnResetClick"
                    ToolTip="Sends ForceFeedbackCommand.Reset — the probe's only device-mutating command (halt-type). Mechanism discrimination for a persisting force." />
            <Button x:Name="ReleaseButton" Content="Release" Padding="14,6" Margin="8,0,0,0" IsEnabled="False" Click="OnReleaseClick" />
        </StackPanel>

        <TextBox x:Name="StatusLog" Grid.Row="3" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                 VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                 TextWrapping="NoWrap" AcceptsReturn="True" />
    </Grid>
</Window>
